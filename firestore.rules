rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Presentation shares — App Check required to write
    match /shares/{id} {
      allow read: if true;
      allow write: if request.app.verified;
    }

    // iOS remote sessions — iOS app creates, web app updates cmd field
    match /remotes/{id} {
      allow read: if true;
      allow write: if true;
    }

    // WebRTC clicker signalling — App Check required to write, anyone can read
    match /clicker/{id} {
      allow read: if true;
      allow write: if request.app.verified;
    }

  }
}
